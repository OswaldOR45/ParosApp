# COPIA este archivo a secrets.toml (local) o pégalo en el panel de
# Community Cloud (Settings > Secrets). NUNCA subas secrets.toml a GitHub.

[gcp_service_account]
type = "service_account"
project_id = "tu-proyecto"
private_key_id = "xxxxxxxx"
private_key = "-----BEGIN PRIVATE KEY-----\nLINEA1\nLINEA2\n-----END PRIVATE KEY-----\n"
client_email = "tu-cuenta@tu-proyecto.iam.gserviceaccount.com"
client_id = "1234567890"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/..."

[app]
spreadsheet_key = "EL_ID_DE_TU_GOOGLE_SHEET"
